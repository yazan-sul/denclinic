generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 1. USER & IDENTITY MANAGEMENT
// ============================================

enum UserRole {
  PATIENT
  DOCTOR
  STAFF
  ADMIN
  CLINIC_OWNER
}

model User {
  id            Int      @id @default(autoincrement())
  phoneNumber   String   
  email         String?  @unique
  emailVerified Boolean  @default(false)
  googleId      String?  @unique
  username      String?  @unique
  password      String // Hashed
  name          String
  roles         UserRole[] @default([PATIENT])
  avatar        String?  // Profile photo URL

  // Relations
  patient        Patient?
  doctorProfiles Doctor[]  @relation("DoctorProfile")
  staffProfiles  Staff[]   @relation("StaffProfile")
  clinicsOwned   Clinic?   @relation("ClinicOwner")

  // Activity
  appointments  Appointment[]
  payments      Payment[]
  ratings       Rating[]
  guardianships PatientGuardian[] @relation("GuardianUser")
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// PATIENT PROFILE
// ============================================

model Patient {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  nationalId String? @unique

  // Medical Info
  dateOfBirth    DateTime?
  gender         String? // male/female
  bloodType      String? // A+, B-, O+, etc.
  allergies      String? // Comma-separated
  medicalHistory String? // Text field for notes

  // Family Links
  guardians PatientGuardian[] @relation("DependentPatient")

  // Bookings
  appointments Appointment[] @relation("PatientAppointment")

  // Dental chart
  teeth Tooth[]

  labOrders LabOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ToothStatus {
  HEALTHY
  DECAYED
  FILLED
  CROWN
  MISSING
}

enum ToothSurface {
  MESIAL
  DISTAL
  OCCLUSAL
  BUCCAL
  LINGUAL
}

model Tooth {
  id          Int      @id @default(autoincrement())
  patientId   Int
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  toothNumber Int
  records     ToothRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([patientId, toothNumber])
  @@index([patientId])
}

model ToothRecord {
  id            Int           @id @default(autoincrement())
  toothId       Int
  tooth         Tooth         @relation(fields: [toothId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  doctorId      Int?
  doctor        Doctor?        @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  status        ToothStatus
  surfaces      ToothSurface[]
  notes         String?
  createdAt     DateTime       @default(now())

  @@index([toothId, createdAt])
  @@index([appointmentId])
  @@index([doctorId])
}

// ============================================
// PATIENT-GUARDIAN RELATIONSHIP (Family)
// ============================================

enum GuardianRelationship {
  SELF
  PARENT
  SPOUSE
  SIBLING
  CHILD
  GRANDPARENT
  OTHER
}

enum GuardianStatus {
  PENDING
  APPROVED
}

model PatientGuardian {
  id             Int  @id @default(autoincrement())
  guardianUserId Int
  guardianUser   User @relation("GuardianUser", fields: [guardianUserId], references: [id], onDelete: Cascade)

  patientId        Int
  dependentPatient Patient @relation("DependentPatient", fields: [patientId], references: [id], onDelete: Cascade)

  relationship       GuardianRelationship
  status             GuardianStatus  @default(APPROVED)
  dependentInitiated Boolean         @default(false)

  @@unique([guardianUserId, patientId])
  @@index([guardianUserId])
  @@index([patientId])
}

// ============================================
// 2. CLINIC & INFRASTRUCTURE
// ============================================

model Clinic {
  id      Int   @id @default(autoincrement())
  ownerId Int?  @unique
  owner   User? @relation("ClinicOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  name        String   @unique
  description String?
  specialty   String // e.g., "Dentistry", "Ophthalmology"
  phone       String?
  email       String?
  website     String?
  logo        String? // URL
  images      String[] // Array of image URLs

  // Stats
  rating      Float @default(4.5)
  reviewCount Int   @default(0)

  // Subscription
  currentSubscriber Boolean       @default(false)
  subscription      Subscription? @relation("ClinicSubscription")

  // Relations
  branches     Branch[]
  services     Service[]
  doctors      Doctor[]
  staff        Staff[]
  appointments Appointment[]
  ratings      Rating[]
  labs         Lab[]
  labOrders    LabOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id       Int    @id @default(autoincrement())
  clinicId Int
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  name      String
  address   String
  phone     String?
  latitude  Float
  longitude Float

  // Relations
  doctors      Doctor[]
  staff        Staff[]
  slots        Slot[]
  appointments Appointment[]
  labOrders    LabOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, name])
  @@index([clinicId])
}

model Service {
  id       Int    @id @default(autoincrement())
  clinicId Int
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  name              String
  description       String?
  icon              String? // Emoji or icon URL
  basePrice         Float? // Default price (can vary by branch/doctor)
  estimatedDuration Int? // In minutes

  // Relations
  doctors      Doctor[]      @relation("DoctorServices")
  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, name])
  @@index([clinicId])
}

// ============================================
// 3. DOCTOR & SCHEDULING
// ============================================

model Doctor {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation("DoctorProfile", fields: [userId], references: [id], onDelete: Cascade)

  clinicId Int
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  // Professional Info
  specialization    String // e.g., "Oral Surgery", "Orthodontics"
  bio               String?
  avatar            String? // URL
  yearsOfExperience Int?
  qualifications    String? // Comma-separated

  // Stats
  rating      Float @default(4.5)
  reviewCount Int   @default(0)

  // Relations
  servicesOffered Service[]     @relation("DoctorServices")
  slots           Slot[]
  appointments    Appointment[]
  toothRecords    ToothRecord[]
  labOrders       LabOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, branchId])
  @@index([clinicId])
  @@index([branchId])
}

// ============================================
// STAFF PROFILE
// ============================================

model Staff {
  id       Int    @id @default(autoincrement())
  userId   Int
  user     User   @relation("StaffProfile", fields: [userId], references: [id], onDelete: Cascade)

  clinicId Int
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  position   String  // e.g., "سكرتيرة", "مساعد طبيب"
  department String? // e.g., "الاستقبال", "المختبر"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, branchId])
  @@index([clinicId])
  @@index([branchId])
}

// ============================================
// 4. SCHEDULING - SLOTS & APPOINTMENTS
// ============================================

model Slot {
  id       Int    @id @default(autoincrement())
  doctorId Int
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  // Time
  slotDate  DateTime // Date of the slot
  startTime String // HH:MM format
  endTime   String // HH:MM format

  // Status
  isAvailable Boolean      @default(true)
  appointment Appointment? // Null if not booked, one if booked

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([doctorId, slotDate, startTime])
  @@index([doctorId])
  @@index([branchId])
  @@index([slotDate])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  CANCELLED
  COMPLETED
  NO_SHOW
  RESCHEDULED
  PAYMENT_FAILED
}

model Appointment {
  id String @id @default(cuid())

  // Patient Info
  patientId Int
  patient   Patient @relation("PatientAppointment", fields: [patientId], references: [id], onDelete: Cascade)
  userId    Int // Who made the booking (could be patient or guardian)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Booking For (which family member)
  bookedForPatientId Int? // If different from patientId (guardian booking for dependent)

  // Medical Details
  clinicId Int
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  doctorId Int
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  serviceId Int
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Slot (optional - could be created without pre-assigned slot)
  slotId Int?  @unique
  slot   Slot? @relation(fields: [slotId], references: [id], onDelete: SetNull)

  // Appointment Time (denormalized for easy access)
  appointmentDate DateTime
  appointmentTime String // HH:MM

  // Status & Notes
  status            AppointmentStatus @default(PENDING)
  retryDeadline     DateTime?
  notes             String?
  reasonForVisit    String?


  // Payment
  payment Payment?

  // Treatment records for this appointment
  treatments Treatment[]
  toothRecords ToothRecord[]

  labOrdersAsOrigin  LabOrder[] @relation("LabOrderOrigin")
  labOrdersAsFitting LabOrder[] @relation("LabOrderFitting")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([userId])
  @@index([clinicId])
  @@index([doctorId])
  @@index([appointmentDate])
  @@index([status])
}

// ============================================
// TREATMENT & LAB CASES
// ============================================

enum TreatmentStatus {
  PLANNED
  ONGOING
  COMPLETED
}

model Treatment {
  id            Int         @id @default(autoincrement())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  status        TreatmentStatus @default(PLANNED)
  diagnosis     String?
  notesPublic   String?
  notesInternal String?
  cost          Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([appointmentId])
}

// ============================================
// LAB MANAGEMENT
// ============================================

model Lab {
  id       Int    @id @default(autoincrement())
  clinicId Int
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  name          String
  phones        String[]
  address       String?
  contactPerson String?
  email         String?
  notes         String?
  isActive      Boolean @default(true)

  labOrders LabOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, name])
  @@index([clinicId])
}

enum LabOrderStatus {
  DRAFT
  SENT_TO_LAB
  UNDER_CONSTRUCTION
  DELAYED
  RECEIVED_AT_CLINIC
  COMPLETED_FITTED
  REJECTED
}

enum ImpressionType {
  PHYSICAL
  DIGITAL
}

enum WorkCategory {
  FIXED_PROSTHODONTICS
  REMOVABLE_PROSTHODONTICS
  ORTHO_APPLIANCES
}

enum WorkType {
  SINGLE_CROWN
  DENTAL_BRIDGE
  VENEER_EMAX
  INLAY_ONLAY
  IMPLANT_CROWN
  COMPLETE_DENTURE
  PARTIAL_ACRYLIC_DENTURE
  CAST_PARTIAL_DENTURE
  FLEXIBLE_DENTURE
  ORTHODONTIC_RETAINER
  NIGHT_GUARD
  CLEAR_ALIGNERS
  STUDY_MODEL
}

enum DentalMaterial {
  ZIRCONIA_SOLID
  ZIRCONIA_LAYERED
  EMAX
  PFM
  FULL_METAL_GOLD
  TEMPORARY_ACRYLIC
  ACRYLIC_RESIN
  COBALT_CHROMIUM
  THERMOPLASTIC_FLEXIBLE
  HARD_ACRYLIC
  SOFT_EVA
}

model LabOrder {
  id       String @id @default(cuid())
  clinicId Int
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  labId    Int
  lab      Lab    @relation(fields: [labId], references: [id])
  patientId Int
  patient   Patient @relation(fields: [patientId], references: [id])
  doctorId  Int?
  doctor    Doctor? @relation(fields: [doctorId], references: [id])

  orderAppointmentId   String?
  orderAppointment     Appointment? @relation("LabOrderOrigin", fields: [orderAppointmentId], references: [id], onDelete: SetNull)

  fittingAppointmentId String?
  fittingAppointment   Appointment? @relation("LabOrderFitting", fields: [fittingAppointmentId], references: [id], onDelete: SetNull)

  status         LabOrderStatus @default(DRAFT)
  impressionType ImpressionType @default(PHYSICAL)

  totalCost     Decimal   @default(0) @db.Decimal(10, 2)  // تكلفة المختبر (ما ندفعه للمختبر)
  patientPrice  Decimal   @default(0) @db.Decimal(10, 2)  // سعر المريض (ما نأخذه من المريض)
  orderDate     DateTime  @default(now())
  sentDate      DateTime?
  expectedDate  DateTime?
  receivedDate  DateTime?
  completedDate DateTime?
  notes         String?

  parentOrderId String?
  parentOrder   LabOrder?  @relation("RemakeOrders", fields: [parentOrderId], references: [id])
  remakeOrders  LabOrder[] @relation("RemakeOrders")

  items LabOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([branchId])
  @@index([patientId])
  @@index([labId])
  @@index([status])
  @@index([orderAppointmentId])
  @@index([fittingAppointmentId])
}

model LabOrderItem {
  id         Int      @id @default(autoincrement())
  labOrderId String
  labOrder   LabOrder @relation(fields: [labOrderId], references: [id], onDelete: Cascade)

  category     WorkCategory
  workType     WorkType
  toothNumbers Int[]
  material     DentalMaterial?
  shade        String?
  stumpShade   String?
  notes        String?
  cost         Float           @default(0)

  createdAt DateTime @default(now())

  @@index([labOrderId])
}

// ============================================
// 5. SUBSCRIPTION SYSTEM (Clinic-Level)
// ============================================

enum SubscriptionTier {
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING_PAYMENT
}

model SubscriptionPlan {
  id   Int              @id @default(autoincrement())
  tier SubscriptionTier @unique

  // Plan Details
  name         String
  description  String?
  monthlyPrice Float
  annualPrice  Float?

  // Features (JSON or text)
  maxBranches     Int      @default(1)
  maxDoctors      Int      @default(10)
  maxAppointments Int? // Null = unlimited
  features        String[] // ["appointment_tracking", "patient_history", "sms_reminders", etc.]

  // Relations
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id       Int    @id @default(autoincrement())
  clinicId Int    @unique
  clinic   Clinic @relation("ClinicSubscription", fields: [clinicId], references: [id], onDelete: Cascade)

  planId Int
  plan   SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  // Dates
  startDate   DateTime  @default(now())
  endDate     DateTime // When subscription expires
  renewalDate DateTime? // Next renewal date

  // Status
  status SubscriptionStatus @default(ACTIVE)

  // Billing
  monthlyBilled Boolean @default(true) // vs annual
  autoRenew     Boolean @default(true)

  // Relations
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([endDate])
}

// ============================================
// 6. PAYMENT SYSTEM
// ============================================

enum Currency {
  ILS // شيكل إسرائيلي
  USD // دولار أمريكي
  JOD // دينار أردني
  EUR // يورو
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  ONLINE_PAYMENT
  INSURANCE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

model Payment {
  id String @id @default(cuid())

  // Payer
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Amount & Method
  amount   Float
  currency Currency      @default(ILS)
  method   PaymentMethod
  status   PaymentStatus @default(PENDING)

  // References (one or both)
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  subscriptionId Int?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  // Transaction
  transactionId   String? // External payment ID
  transactionTime DateTime @default(now())

  // Discount
  originalAmount Float?  // Amount before discount
  discountType   String? // NONE | PERCENTAGE | FIXED
  discountValue  Float?  // e.g. 10 for 10% or 50 for 50 fixed

  // Multi-currency payment
  paidAmount   Float?    // What patient actually paid
  paidCurrency Currency? // Currency of the payment
  exchangeRate Float?    // Rate: 1 unit paidCurrency = X units of currency (cost currency)
  surplus      Float?    // Positive = overpaid, negative = underpaid (in cost currency)

  // Notes
  description String? // Invoice description
  receiptUrl  String? // URL to receipt/invoice

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions PaymentTransaction[]

  @@index([userId])
  @@index([status])
  @@index([transactionTime])
}

model PaymentTransaction {
  id String @id @default(cuid())

  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  paidAmount   Float
  paidCurrency Currency
  exchangeRate Float         @default(1)
  amountInCost Float         // paidAmount * exchangeRate (in invoice currency)
  method       PaymentMethod
  notes        String?

  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([paymentId])
  @@index([paidAt])
}

// ============================================
// 7. RATINGS & REVIEWS
// ============================================

model Rating {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  clinicId Int
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  rating  Float // 1-5
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, clinicId])
  @@index([clinicId])
  @@index([rating])
}

// ============================================
// 8. NOTIFICATIONS
// ============================================

enum NotificationType {
  CLINIC_ASSIGNMENT
  APPOINTMENT_REMINDER
  APPOINTMENT_UPDATED
  GENERAL
}

model Notification {
  id      Int  @id @default(autoincrement())
  userId  Int
  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       NotificationType @default(GENERAL)
  title      String
  message    String
  isRead     Boolean  @default(false)
  link       String?
  targetRole String?  // 'DOCTOR' | 'STAFF' | 'PATIENT' | 'CLINIC_OWNER' | 'ADMIN' | null = all roles

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, targetRole])
}
