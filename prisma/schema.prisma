generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 1. USER & IDENTITY MANAGEMENT
// ============================================

enum UserRole {
  PATIENT
  DOCTOR
  STAFF
  ADMIN
  CLINIC_OWNER
}

model User {
  id            Int      @id @default(autoincrement())
  phoneNumber   String   
  email         String?  @unique
  emailVerified Boolean  @default(false)
  googleId      String?  @unique
  username      String?  @unique
  password      String // Hashed
  name          String
  roles         UserRole[] @default([PATIENT])
  avatar        String?  // Profile photo URL

  // Relations
  patient       Patient?
  doctorProfile Doctor?   @relation("DoctorProfile")
  staffProfile  Staff?    @relation("StaffProfile")
  clinicsOwned  Clinic?  @relation("ClinicOwner")

  // Activity
  appointments  Appointment[]
  payments      Payment[]
  ratings       Rating[]
  guardianships PatientGuardian[] @relation("GuardianUser")
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// PATIENT PROFILE
// ============================================

model Patient {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identity
  nationalId String? // National ID number

  // Medical Info
  dateOfBirth    DateTime?
  gender         String? // male/female
  bloodType      String? // A+, B-, O+, etc.
  allergies      String? // Comma-separated
  medicalHistory String? // Text field for notes

  // Family Links
  guardians PatientGuardian[] @relation("DependentPatient")

  // Bookings
  appointments Appointment[] @relation("PatientAppointment")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// PATIENT-GUARDIAN RELATIONSHIP (Family)
// ============================================

enum GuardianRelationship {
  SELF
  PARENT
  SPOUSE
  SIBLING
  CHILD
  GRANDPARENT
  OTHER
}

model PatientGuardian {
  id             Int  @id @default(autoincrement())
  guardianUserId Int
  guardianUser   User @relation("GuardianUser", fields: [guardianUserId], references: [id], onDelete: Cascade)

  patientId        Int
  dependentPatient Patient @relation("DependentPatient", fields: [patientId], references: [id], onDelete: Cascade)

  relationship GuardianRelationship // How guardian relates to patient

  @@unique([guardianUserId, patientId])
  @@index([guardianUserId])
  @@index([patientId])
}

// ============================================
// 2. CLINIC & INFRASTRUCTURE
// ============================================

model Clinic {
  id      Int   @id @default(autoincrement())
  ownerId Int?  @unique
  owner   User? @relation("ClinicOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  name        String   @unique
  description String?
  specialty   String // e.g., "Dentistry", "Ophthalmology"
  phone       String?
  email       String?
  website     String?
  logo        String? // URL
  images      String[] // Array of image URLs

  // Stats
  rating      Float @default(4.5)
  reviewCount Int   @default(0)

  // Subscription
  currentSubscriber Boolean       @default(false)
  subscription      Subscription? @relation("ClinicSubscription")

  // Relations
  branches     Branch[]
  services     Service[]
  doctors      Doctor[]
  staff        Staff[]
  appointments Appointment[]
  ratings      Rating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id       Int    @id @default(autoincrement())
  clinicId Int
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  name      String
  address   String
  phone     String?
  latitude  Float
  longitude Float

  // Relations
  doctors      Doctor[]
  staff        Staff[]
  slots        Slot[]
  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, name])
  @@index([clinicId])
}

model Service {
  id       Int    @id @default(autoincrement())
  clinicId Int
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  name              String
  description       String?
  icon              String? // Emoji or icon URL
  basePrice         Float? // Default price (can vary by branch/doctor)
  estimatedDuration Int? // In minutes

  // Relations
  doctors      Doctor[]      @relation("DoctorServices")
  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clinicId, name])
  @@index([clinicId])
}

// ============================================
// 3. DOCTOR & SCHEDULING
// ============================================

model Doctor {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation("DoctorProfile", fields: [userId], references: [id], onDelete: Cascade)

  clinicId Int
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  // Professional Info
  specialization    String // e.g., "Oral Surgery", "Orthodontics"
  bio               String?
  avatar            String? // URL
  yearsOfExperience Int?
  qualifications    String? // Comma-separated

  // Stats
  rating      Float @default(4.5)
  reviewCount Int   @default(0)

  // Relations
  servicesOffered Service[]     @relation("DoctorServices")
  slots           Slot[]
  appointments    Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, branchId])
  @@index([clinicId])
  @@index([branchId])
}

// ============================================
// STAFF PROFILE
// ============================================

model Staff {
  id       Int    @id @default(autoincrement())
  userId   Int    @unique
  user     User   @relation("StaffProfile", fields: [userId], references: [id], onDelete: Cascade)

  clinicId Int
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  position   String  // e.g., "سكرتيرة", "مساعد طبيب"
  department String? // e.g., "الاستقبال", "المختبر"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
  @@index([branchId])
}

// ============================================
// 4. SCHEDULING - SLOTS & APPOINTMENTS
// ============================================

model Slot {
  id       Int    @id @default(autoincrement())
  doctorId Int
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  // Time
  slotDate  DateTime // Date of the slot
  startTime String // HH:MM format
  endTime   String // HH:MM format

  // Status
  isAvailable Boolean      @default(true)
  appointment Appointment? // Null if not booked, one if booked

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([doctorId, slotDate, startTime])
  @@index([doctorId])
  @@index([branchId])
  @@index([slotDate])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  RESCHEDULED
  PAYMENT_FAILED
}

model Appointment {
  id String @id @default(cuid())

  // Patient Info
  patientId Int
  patient   Patient @relation("PatientAppointment", fields: [patientId], references: [id], onDelete: Cascade)
  userId    Int // Who made the booking (could be patient or guardian)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Booking For (which family member)
  bookedForPatientId Int? // If different from patientId (guardian booking for dependent)

  // Medical Details
  clinicId Int
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  doctorId Int
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  serviceId Int
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Slot (optional - could be created without pre-assigned slot)
  slotId Int?  @unique
  slot   Slot? @relation(fields: [slotId], references: [id], onDelete: SetNull)

  // Appointment Time (denormalized for easy access)
  appointmentDate DateTime
  appointmentTime String // HH:MM

  // Status & Notes
  status            AppointmentStatus @default(PENDING)
  retryDeadline     DateTime?
  notes             String?
  reasonForVisit    String?


  // Payment
  payment Payment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([userId])
  @@index([clinicId])
  @@index([doctorId])
  @@index([appointmentDate])
  @@index([status])
}

// ============================================
// 5. SUBSCRIPTION SYSTEM (Clinic-Level)
// ============================================

enum SubscriptionTier {
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING_PAYMENT
}

model SubscriptionPlan {
  id   Int              @id @default(autoincrement())
  tier SubscriptionTier @unique

  // Plan Details
  name         String
  description  String?
  monthlyPrice Float
  annualPrice  Float?

  // Features (JSON or text)
  maxBranches     Int      @default(1)
  maxDoctors      Int      @default(10)
  maxAppointments Int? // Null = unlimited
  features        String[] // ["appointment_tracking", "patient_history", "sms_reminders", etc.]

  // Relations
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id       Int    @id @default(autoincrement())
  clinicId Int    @unique
  clinic   Clinic @relation("ClinicSubscription", fields: [clinicId], references: [id], onDelete: Cascade)

  planId Int
  plan   SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  // Dates
  startDate   DateTime  @default(now())
  endDate     DateTime // When subscription expires
  renewalDate DateTime? // Next renewal date

  // Status
  status SubscriptionStatus @default(ACTIVE)

  // Billing
  monthlyBilled Boolean @default(true) // vs annual
  autoRenew     Boolean @default(true)

  // Relations
  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([endDate])
}

// ============================================
// 6. PAYMENT SYSTEM
// ============================================

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  ONLINE_PAYMENT
  INSURANCE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

model Payment {
  id String @id @default(cuid())

  // Payer
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Amount & Method
  amount   Float
  currency String        @default("EGP") // Egyptian Pound
  method   PaymentMethod
  status   PaymentStatus @default(PENDING)

  // References (one or both)
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  subscriptionId Int?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  // Transaction
  transactionId   String? // External payment ID
  transactionTime DateTime @default(now())

  // Notes
  description String? // Invoice description
  receiptUrl  String? // URL to receipt/invoice

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([transactionTime])
}

// ============================================
// 7. RATINGS & REVIEWS
// ============================================

model Rating {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  clinicId Int
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  rating  Float // 1-5
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, clinicId])
  @@index([clinicId])
  @@index([rating])
}

// ============================================
// 8. NOTIFICATIONS
// ============================================

enum NotificationType {
  CLINIC_ASSIGNMENT
  APPOINTMENT_REMINDER
  APPOINTMENT_UPDATED
  GENERAL
}

model Notification {
  id      Int  @id @default(autoincrement())
  userId  Int
  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType @default(GENERAL)
  title   String
  message String
  isRead  Boolean  @default(false)
  link    String?  // Optional deep-link

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, isRead])
}
