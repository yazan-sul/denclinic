{
  "name": "denclinic",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "test:api:records": "tsx tests/records-api.integration.ts",
    "db:studio": "prisma studio --browser none",
    "db:migrate:reset": "prisma migrate reset --force",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:fresh": "prisma migrate reset --force && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.2",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-oauth/google": "^0.13.5",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@types/three": "^0.184.0",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.6.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "minimatch": "^10.2.4",
    "next": "^16.2.3",
    "next-pwa": "^5.6.0",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "resend": "^6.12.0",
    "three": "^0.184.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.58.1",
    "@types/leaflet": "^1.9.21",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^20.19.37",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
